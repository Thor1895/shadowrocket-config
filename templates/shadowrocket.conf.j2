# Generated by shadowrocket-config. Do not edit by hand.

[General]
bypass-system = {{ "true" if settings.general.bypass_system else "false" }}
skip-proxy = {{ settings.general.skip_proxy | join(", ") }}
dns-server = {{ settings.general.dns_server | join(", ") }}

[Proxy]
# 节点由 Shadowrocket 中单独添加的机场订阅提供，本配置不内置任何节点。

[Proxy Group]
{% for group in groups %}
{{ group.name }} = {{ group.type }}{% if group.options is defined and group.options %},{{ group.options | join(",") }}{% endif %}{% if group.members is defined and group.members %},{{ group.members | join(",") }}{% endif %}{{ "\n" }}{% endfor %}

[Rule]
{% for section in rules %}
# {{ section.name }}
{% for item in section["items"] %}
{{ item }}
{% endfor %}
{% endfor %}
